# ===== Mantle Network =====
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003
# Your wallet private key (with MNT on Mantle Sepolia for gas)
# NEVER commit this to git — get testnet MNT from faucet: https://faucet.sepolia.mantle.xyz
PRIVATE_KEY=

# ===== Bybit Testnet =====
BYBIT_TESTNET=true
# Get API keys from: https://testnet.bybit.com → API Management
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_REST_URL=https://api-testnet.bybit.com
BYBIT_WS_URL=wss://stream-testnet.bybit.com/v5

# ===== LLM Provider =====
# Supported providers:
#   1. Ollama Cloud (recommended for hackathon)
#      API URL: https://ollama.com/api (or https://ollama.com/v1 for OpenAI-compatible)
#      Get API key from: https://ollama.com → Settings → API Keys
#   2. Local Ollama (free, requires GPU)
#      API URL: http://localhost:11434
#   3. Any OpenAI-compatible API (Groq, Together, OpenRouter, etc.)
#      API URL: provider's endpoint
#      API Key: provider's key
#      Model: provider's model name

# LLM API URL (default: local Ollama)
OLLAMA_API_URL=http://localhost:11434
# LLM API key (empty for local Ollama, required for Ollama Cloud and other providers)
OLLAMA_API_KEY=
# Model to use for trading decisions (default: qwen2.5:7b)
# Recommended models (cheapest to most expensive):
#   - qwen2.5:7b      (fast, good at JSON, cheapest — recommended)
#   - qwen2.5:14b     (better reasoning, moderate cost)
#   - qwen2.5:32b     (best reasoning, higher cost)
#   - llama3.1:8b     (decent alternative)
#   - mistral:7b      (good at instructions, fast)
#   - For OpenAI-compatible providers, use their model name (e.g., gpt-4o-mini)
OLLAMA_MODEL=qwen2.5:7b

# ===== Postgres (Docker) =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tradehunt
POSTGRES_USER=tradehunt
POSTGRES_PASSWORD=tradehunt_dev

# ===== API Server =====
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ===== Deployed Contracts (Mantle Sepolia) =====
# These are auto-populated after running Deploy.s.sol
DEPLOYER_ADDRESS=
ERC8004_REGISTRY_ADDRESS=
AGENT_IDENTITY_ADDRESS=
TRADE_REGISTRY_ADDRESS=
ARENA_LEADERBOARD_ADDRESS=
REPUTATION_FEED_ADDRESS=

# ===== Covalent (optional) =====
# Get API key from: https://www.covalenthq.com → Dashboard → API Keys
COVALENT_API_KEY=